# Ignore the actual configuration file containing passwords
ssmtp.conf

# Ignore local log files
*.log
tmp.*

# Ignore system files
.DS_Store
Thumbs.db

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class

# Coverage reports and generated artifacts
coverage/
coverage_*/
kcov-merged/
mocks/
scripts_test/
pi-scripts/
*.txt
code-coverage-results.md
